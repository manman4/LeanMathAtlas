/-
  # 練習問題
  各トピックから sorry を使った練習問題を用意。
  sorry を消して自分で証明を書いてみよう！

  ヒント:
  - VSCode で Lean InfoView パネルを開くと、現在のゴールと仮定が表示される
  - sorry の位置にカーソルを置くと、何を証明すべきかわかる
  - タクティクスを1つずつ入力して、ゴールがどう変化するか観察しよう
-/
import Mathlib.Tactic

-- ============================================================
-- 練習 1: 含意の基本（難易度: ★）
-- ヒント: intro と exact を使う
-- ============================================================

example (P Q : Prop) (hp : P) (_hq : Q) : P := by
  sorry

-- ============================================================
-- 練習 2: 含意の連鎖（難易度: ★）
-- ヒント: intro と apply を使う
-- ============================================================

example (P Q R : Prop) : (P → Q) → (Q → R) → P → R := by
  sorry

-- ============================================================
-- 練習 3: 論理積（難易度: ★）
-- ヒント: constructor で分割し、各サブゴールを exact で閉じる
-- ============================================================

example (P Q : Prop) (hp : P) (hq : Q) : P ∧ Q := by
  sorry

-- ============================================================
-- 練習 4: 論理積の分解（難易度: ★★）
-- ヒント: obtain ⟨_, _⟩ := h で分解してから constructor
-- ============================================================

example (P Q : Prop) : P ∧ Q → Q ∧ P := by
  sorry

-- ============================================================
-- 練習 5: 論理和（難易度: ★★）
-- ヒント: rcases h with hp | hq で場合分けし、left/right で方向を選ぶ
-- ============================================================

example (P Q R : Prop) : P ∨ Q → (P → R) → (Q → R) → R := by
  sorry

-- ============================================================
-- 練習 6: rw を使った書き換え（難易度: ★）
-- ヒント: rw [h] でゴールを書き換える
-- ============================================================

example (a b c : Nat) (h1 : a = b) (h2 : b = c) : a = c := by
  sorry

-- ============================================================
-- 練習 7: ring を使った代数的等式（難易度: ★）
-- ヒント: ring タクティクス1つで解ける
-- ============================================================

example (x y : Int) : (x + y) ^ 2 = x ^ 2 + 2 * x * y + y ^ 2 := by
  sorry

-- ============================================================
-- 練習 8: omega を使った不等式（難易度: ★）
-- ヒント: omega タクティクス1つで解ける
-- ============================================================

example (n m : Nat) (h : n ≤ m) : n ≤ m + 1 := by
  sorry

-- ============================================================
-- 練習 9: 帰納法（難易度: ★★★）
-- ヒント: induction n with で場合分けし、
--        base case は simp で、inductive step は rw と ih を使う
-- ============================================================

theorem my_zero_add (n : Nat) : 0 + n = n := by
  sorry

-- ============================================================
-- 練習 10: 偶数の証明（難易度: ★★★）
-- ヒント: obtain で偶数の定義を分解し、
--        ⟨式, by omega⟩ の形で Even を構成する
-- ============================================================

theorem my_even_add (a b : Nat) (ha : Even a) (hb : Even b) : Even (a + b) := by
  sorry
