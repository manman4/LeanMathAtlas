/-
  # 主要タクティクスの練習
  Lean 4 で証明を書くために使う主要なタクティクスを練習する

  各タクティクスの概念説明は docs/ja/Tactics.md を参照。
-/
import Mathlib.Tactic

-- ============================================================
-- 1. rfl — 反射律 (reflexivity)
-- ============================================================

-- rfl: 両辺が定義上等しい場合に等式を証明する
example : 1 + 1 = 2 := by rfl

example : "hello" ++ " world" = "hello world" := by rfl

-- 変数を含む場合も、定義から明らかなら rfl で証明できる
example (n : Nat) : n + 0 = n := by rfl

-- ============================================================
-- 2. rw — 書き換え (rewrite)
-- ============================================================

-- rw [h]: 仮定 h : a = b を使って、ゴールの a を b に書き換える
example (a b : Nat) (h : a = b) : a + 1 = b + 1 := by
  rw [h]   -- ゴールが b + 1 = b + 1 になり、rfl で自動解決

-- rw [← h]: 逆方向に書き換える（b を a に）
example (a b : Nat) (h : a = b) : b + 1 = a + 1 := by
  rw [← h]

-- 複数の書き換え
example (a b c : Nat) (h1 : a = b) (h2 : b = c) : a = c := by
  rw [h1, h2]

-- 仮定の中を書き換える: rw [h] at h2
example (a b : Nat) (h : a = b) (h2 : a > 0) : b > 0 := by
  rw [← h]
  exact h2

-- ============================================================
-- 3. simp — 単純化 (simplification)
-- ============================================================

-- simp: Lean が知っている単純化規則を自動適用する
example (n : Nat) : n + 0 = n := by simp

example (n : Nat) : 0 + n = n := by simp

example (a b : Nat) : (a + b) - (a + b) = 0 := by simp

-- simp に補題を追加して使う
example (a b : Nat) (h : a = b) : a + 1 = b + 1 := by
  simp [h]

-- ============================================================
-- 4. ring — 環の等式
-- ============================================================

-- ring: 加法・乗法に関する等式を自動的に証明する
-- （整数、自然数、有理数など「環」の構造を持つ型で使える）
example (a b : Nat) : (a + b) * (a + b) = a * a + 2 * a * b + b * b := by
  ring

example (x : Int) : (x + 1) * (x - 1) = x ^ 2 - 1 := by
  ring

example (a b c : Int) : (a + b + c) ^ 2 = a^2 + b^2 + c^2 + 2*a*b + 2*b*c + 2*a*c := by
  ring

-- ============================================================
-- 5. omega — 線形算術
-- ============================================================

-- omega: 自然数・整数の線形不等式/等式を自動的に証明する
example : 2 + 3 = 5 := by omega

example (n : Nat) : n < n + 1 := by omega

example (a b : Nat) (h : a ≤ b) : a ≤ b + 1 := by omega

example (n : Nat) (h : n ≥ 1) : n > 0 := by omega

-- ============================================================
-- 6. linarith — 線形算術（より一般的）
-- ============================================================

-- linarith: 線形不等式の組み合わせから結論を導く
example (a b : Int) (h1 : a ≤ b) (h2 : b ≤ a) : a = b := by
  linarith

example (x y : Int) (h1 : x + y ≤ 10) (h2 : x ≥ 3) (h3 : y ≥ 8) : False := by
  linarith

example (a b c : Int) (h1 : a + b ≤ c) (h2 : c ≤ a) : b ≤ 0 := by
  linarith

-- ============================================================
-- 7. have — 補題の導入
-- ============================================================

-- have: 証明の途中で補助的な命題を示す
example (a b c : Nat) (h1 : a ≤ b) (h2 : b ≤ c) : a ≤ c := by
  have h3 : a ≤ c := Nat.le_trans h1 h2
  exact h3

-- have をタクティクスで証明する
example (n : Nat) (h : n > 0) : n * 2 > 0 := by
  have h1 : n ≥ 1 := h
  omega

-- ============================================================
-- 8. calc — 計算証明（ステップバイステップ）
-- ============================================================

-- calc: 等式や不等式を段階的に示す
example (a b c : Int) (h1 : a = b + 1) (h2 : b = c + 1) : a = c + 2 := by
  calc a = b + 1     := h1
    _ = (c + 1) + 1  := by rw [h2]
    _ = c + 2        := by ring

-- calc で不等式の連鎖
example (a b c : Nat) (h1 : a ≤ b) (h2 : b < c) : a < c := by
  calc a ≤ b := h1
    _ < c := h2

-- ============================================================
-- 9. norm_num — 数値計算
-- ============================================================

-- norm_num: 具体的な数値に関する命題を証明する
example : (2 : Nat) + 3 = 5 := by norm_num

example : (7 : Int) * 8 = 56 := by norm_num

example : (10 : Nat) ≠ 11 := by norm_num

-- ============================================================
-- 10. タクティクスの組み合わせ
-- ============================================================

-- 複数のタクティクスを組み合わせた例
example (a b : Int) (h : a + b = 10) : (a + b) * 2 = 20 := by
  rw [h]
  norm_num

example (n : Nat) (h : n = 5) : n * n = 25 := by
  subst h    -- subst: 等式 h : n = 5 を使って n を 5 に置換する
  norm_num
